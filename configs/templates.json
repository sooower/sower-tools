{
    "templateRoot": "templates/api",
    "templates": {
        "api.fomoremit.net": {
            "external": [
                {
                    "fileName": "index.ts",
                    "templateName": "src.api.index.ts.tpl"
                },
                {
                    "fileName": "ListGet.ts",
                    "dynamicFileName": true,
                    "templateName": "src.api.list.ts.tpl"
                },
                {
                    "fileName": "Create.ts",
                    "dynamicFileName": true,
                    "templateName": "src.api.create.ts.tpl"
                }
            ],
            "internal": [
                {
                    "fileName": "index.ts",
                    "prefix": "@id",
                    "templateName": "@id/src.api.index.ts.tpl"
                },
                {
                    "fileName": "Get.ts",
                    "dynamicFileName": true,
                    "prefix": "@id",
                    "templateName": "@id/src.api.get.ts.tpl"
                },
                {
                    "fileName": "Update.ts",
                    "dynamicFileName": true,
                    "prefix": "@id",
                    "templateName": "@id/src.api.update.ts.tpl"
                },
                {
                    "fileName": "Delete.ts",
                    "dynamicFileName": true,
                    "prefix": "@id",
                    "templateName": "@id/src.api.delete.ts.tpl"
                }
            ]
        },
        "ibanking.fomopay.com": {
